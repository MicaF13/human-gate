# ---- World ID Developer Portal values (https://developer.worldcoin.org) ----
# Create an app, then an "Incognito Action". Copy the values below.
# The action's "Max verifications per person" MUST be set to 0 (unlimited),
# because login/checkout are recurring actions the same human repeats.

# Your app id, looks like: app_1234567890abcdef
APP_ID=app_staging_replace_me
NEXT_PUBLIC_APP_ID=app_staging_replace_me

# The action identifier you created in the portal, e.g. "verify-human"
ACTION_ID=verify-human
NEXT_PUBLIC_ACTION_ID=verify-human

# A long random string used to sign session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_me_with_a_64_char_random_hex_string
